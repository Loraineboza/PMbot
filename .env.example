# Telegram bot token from @BotFather.
# Keep the real token only in local .env or hosting secrets.
BOT_TOKEN=put_your_bot_token_here

# Comma-separated Telegram numeric IDs for admins, for example:
# ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# Consultant public username is safe to keep here.
CONSULTANT_USERNAME=Elfrida777

# Optional: numeric Telegram ID of consultant, only if the consultant opened the bot.
# Without this ID the bot will show a t.me link and notify admins.
CONSULTANT_TG_ID=

DATABASE_PATH=data/fitline_pm_bot.sqlite3
LOG_LEVEL=INFO
THROTTLE_SECONDS=0.8
REMINDER_CHECK_SECONDS=3600

PM_SITE_URL=https://www.pm-international.com/ru/
PM_PRODUCTS_URL=https://www.pm-international.com/ru/ru-ru/about-our-products
FITLINE_SHOP_URL=https://www.fitline.com/
REGISTRATION_URL=https://www.pmebusiness.com/registrationv2/

